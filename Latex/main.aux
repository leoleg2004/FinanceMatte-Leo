\@writefile{toc}{\contentsline {chapter}{\numberline {4}Ottimizzazione Matematica: Script 8 (Markowitz Pura)}{9}{chapter.4}\protected@file@percent }
\@writefile{lof}{\addvspace {10\p@ }}
