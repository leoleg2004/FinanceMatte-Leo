\@writefile{toc}{\contentsline {section}{\numberline {4.1}Modello Media-Varianza e Frontiera Efficiente}{9}{section.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4.2}Identificazione del Punto Ottimo (Tangency Portfolio)}{10}{section.4.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4.3}Analisi Comparativa: Scarto di Efficienza}{10}{section.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces Frontiera Efficiente generata dallo Script 8. In verde (diamante) il Tangency Portfolio calcolato matematicamente. In ciano (triangolo) l'allocazione empirica scelta dall'utente. Questa curva, definita formalmente \emph  {Frontiera Efficiente}, mostra che per ogni livello di tolleranza al rischio (sull'asse delle ascisse) esiste un solo portafoglio (asse delle ordinate) che matematicamente estrae il massimo rendimento possibile.}}{11}{figure.caption.4}\protected@file@percent }
\newlabel{fig:markowitz}{{4.1}{11}{Frontiera Efficiente generata dallo Script 8. In verde (diamante) il Tangency Portfolio calcolato matematicamente. In ciano (triangolo) l'allocazione empirica scelta dall'utente. Questa curva, definita formalmente \emph {Frontiera Efficiente}, mostra che per ogni livello di tolleranza al rischio (sull'asse delle ascisse) esiste un solo portafoglio (asse delle ordinate) che matematicamente estrae il massimo rendimento possibile}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.4}Oltre Markowitz: Ottimizzazione Mean-VaR (Script 10)}{11}{section.4.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Frontiera Efficiente Mean-VaR: Ogni punto rappresenta un'allocazione simulata. Invece della Varianza, sull'asse delle ascisse misuriamo la Perdita Massima Storica attesa al 95\% (VaR). Il diamante verde è il portafoglio a Minimo VaR, mentre il triangolo ciano è un'allocazione equo-pesata dell'utente. Si nota l'evidente "curvatura" di efficienza.}}{12}{figure.caption.5}\protected@file@percent }
\newlabel{fig:min_var_portfolio}{{4.2}{12}{Frontiera Efficiente Mean-VaR: Ogni punto rappresenta un'allocazione simulata. Invece della Varianza, sull'asse delle ascisse misuriamo la Perdita Massima Storica attesa al 95\% (VaR). Il diamante verde è il portafoglio a Minimo VaR, mentre il triangolo ciano è un'allocazione equo-pesata dell'utente. Si nota l'evidente "curvatura" di efficienza}{figure.caption.5}{}}
